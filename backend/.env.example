APP_ENV=dev
APP_PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=app_db
DB_SSLMODE=disable
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
SIGNATURE_UPLOAD_DIR=./uploads/signatures
SIGNATURE_MAX_BYTES=2097152
SIGNATURE_ALLOWED_TYPES=image/png,image/jpeg
